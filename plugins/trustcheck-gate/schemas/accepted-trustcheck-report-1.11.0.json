{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:trustcheck-gate:accepted-trustcheck-report:1.11.0",
  "title": "Accepted Trustcheck report subset for adapter 0.1",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "const": "1.11.0" },
    "report": { "$ref": "#/$defs/package_report" },
    "reports": {
      "type": "array",
      "items": { "$ref": "#/$defs/package_report" }
    },
    "failures": {
      "type": "array",
      "items": { "$ref": "#/$defs/failure" }
    }
  },
  "oneOf": [
    { "required": ["report"] },
    { "required": ["reports"] }
  ],
  "$defs": {
    "failure": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "requirement": { "type": "string" },
        "message": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "package_report": {
      "type": "object",
      "required": [
        "project",
        "version",
        "policy",
        "vulnerabilities",
        "risk_flags",
        "malicious_package"
      ],
      "properties": {
        "project": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "recommendation": { "type": "string" },
        "policy": {
          "type": "object",
          "required": ["passed", "violations"],
          "properties": {
            "passed": { "type": "boolean" },
            "violations": { "type": "array" }
          },
          "additionalProperties": true
        },
        "vulnerabilities": { "type": "array" },
        "risk_flags": { "type": "array" },
        "malicious_package": {
          "type": "object",
          "required": ["findings"],
          "properties": {
            "findings": { "type": "array" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
