{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:trustcheck-gate:adapter-result:0.1",
  "title": "Trustcheck Gate adapter result",
  "type": "object",
  "required": [
    "adapter_schema_version",
    "operation",
    "classification",
    "policy_permits_install"
  ],
  "properties": {
    "adapter_schema_version": { "const": "0.1.0" },
    "operation": { "type": "string" },
    "classification": {
      "enum": ["passed", "security_findings", "usage_error", "scan_failed"]
    },
    "policy_permits_install": { "type": "boolean" },
    "execution_status": {
      "enum": [
        "completed",
        "timed_out",
        "output_limit_exceeded",
        "failed_to_start",
        "terminated"
      ]
    },
    "report_status": {
      "enum": ["valid", "malformed", "incompatible", "missing", "invalid_schema"]
    },
    "security_status": {
      "enum": ["passed", "findings", "blocked", "unknown", "scan_failed"]
    },
    "report_schema_version": { "type": ["string", "null"] },
    "trustcheck_version": { "type": ["string", "null"] },
    "trustcheck_command_source": {
      "type": ["string", "null"],
      "enum": ["path", "python-module", null]
    },
    "command": {
      "type": "array",
      "items": { "type": "string" }
    },
    "exit_code": { "type": "integer" },
    "duration_seconds": { "type": "number" },
    "stderr": { "type": "string" },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "findings": { "type": "object" },
    "report": { "type": ["object", "null"] },
    "reports": { "type": "array" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "classification": { "const": "passed" }
        }
      },
      "then": {
        "properties": {
          "policy_permits_install": { "const": true },
          "execution_status": { "const": "completed" },
          "report_status": { "const": "valid" },
          "security_status": { "const": "passed" }
        }
      }
    }
  ]
}
