{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:trustcheck:plugin-statement:1",
  "title": "Trustcheck signed plugin statement v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "name",
    "kind",
    "entry_point",
    "api_version",
    "distribution",
    "distribution_version",
    "wheel_sha256",
    "record_sha256",
    "configuration_schema_sha256",
    "protocol_version",
    "capabilities",
    "dependencies"
  ],
  "properties": {
    "schema": {
      "const": "urn:trustcheck:plugin-statement:1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "advisory",
        "index",
        "artifact",
        "policy",
        "renderer"
      ]
    },
    "entry_point": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.]*:[A-Za-z_][A-Za-z0-9_.]*$"
    },
    "api_version": {
      "const": "1"
    },
    "distribution": {
      "type": "string",
      "minLength": 1
    },
    "distribution_version": {
      "type": "string",
      "minLength": 1
    },
    "wheel_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "record_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "configuration_schema_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "protocol_version": {
      "const": "1"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "query",
          "analyze",
          "evaluate",
          "render",
          "supports",
          "create_client",
          "client.get_project",
          "client.download",
          "client.find_dependency_confusion",
          "client.locate_artifact_index"
        ]
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
